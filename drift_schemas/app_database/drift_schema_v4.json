  "fixed_sql": [
    {
      "name": "foods",
      "sql": [
        {
          "dialect": "sqlite",
          "sql": "CREATE TABLE IF NOT EXISTS \"foods\" (\"id\" INTEGER NOT NULL PRIMARY KEY AUTOINCREMENT, \"name\" TEXT NOT NULL COLLATE NOCASE UNIQUE CHECK (name = trim(name) AND length(name) > 0), \"calories_per_serving\" REAL NOT NULL CHECK(\"calories_per_serving\" >= 0.0), \"created_at\" INTEGER NOT NULL, \"updated_at\" INTEGER NOT NULL, \"deleted_at\" INTEGER NULL);"
        }
      ]
    },
    {
      "name": "meal_entries",
      "sql": [
        {
          "dialect": "sqlite",
          "sql": "CREATE TABLE IF NOT EXISTS \"meal_entries\" (\"id\" INTEGER NOT NULL PRIMARY KEY AUTOINCREMENT, \"food_id\" INTEGER NULL REFERENCES foods (id) ON DELETE SET NULL, \"food_name_snapshot\" TEXT NOT NULL CHECK (food_name_snapshot = trim(food_name_snapshot) AND length(food_name_snapshot) > 0 ), \"calories_per_serving_snapshot\" REAL NOT NULL CHECK(\"calories_per_serving_snapshot\" >= 0.0), \"serving_quantity\" REAL NOT NULL CHECK(\"serving_quantity\" > 0.0), \"meal_category\" TEXT NOT NULL CHECK (meal_category IN ('breakfast', 'lunch', 'dinner', 'snack')), \"consumed_at\" INTEGER NOT NULL, \"created_at\" INTEGER NOT NULL);"
        }
      ]
    },
